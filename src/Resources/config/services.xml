<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <service id="MaxMind\Subscriber\ClientIpCaptureSubscriber">
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="MaxMind\Subscriber\OrderPlacedSubscriber">
            <argument type="service" id="messenger.bus.default"/>
            <argument type="service" id="logger"/>
            <argument type="service" id="request_stack"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="MaxMind\Subscriber\TransactionStateSubscriber">
            <argument type="service" id="order_transaction.repository"/>
            <argument type="service" id="logger"/>
            <argument type="service" id="MaxMind\Service\MaxMindFraudService"/>
            <argument type="service" id="request_stack"/>
            <tag name="kernel.event_subscriber"/>
        </service>
        <service id="MaxMind\Service\MaxMindFraudService" public="true">
            <argument type="service" id="order.repository"/>
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="logger"/>
            <argument type="service" id="Shopware\Core\System\StateMachine\StateMachineRegistry"/>
            <argument type="service" id="MaxMind\Service\MaxMindAverageService"/>
        </service>
        <service id="MaxMind\Controller\OrderDetailController" public="true">
            <argument type="service" id="order.repository"/>
            <tag name="controller.service_arguments"/>
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>
        <service id="MaxMind\Service\Installer\StateInstallerHelper">
            <argument type="service" id="state_machine.repository"/>
            <argument type="service" id="state_machine_state.repository"/>
            <argument type="service" id="state_machine_transition.repository"/>
            <argument type="service" id="state_machine_history.repository"/>
        </service>

        <service id="MaxMind\Service\Installer\FraudReviewStateInstaller" public="true">
            <argument type="service" id="MaxMind\Service\Installer\StateInstallerHelper"/>
        </service>

        <service id="MaxMind\Service\Installer\PendingFraudReviewStateInstaller" public="true">
            <argument type="service" id="MaxMind\Service\Installer\StateInstallerHelper"/>
        </service>

        <service id="MaxMind\Service\Installer\FraudPassStateInstaller" public="true">
            <argument type="service" id="MaxMind\Service\Installer\StateInstallerHelper"/>
        </service>

        <service id="MaxMind\Service\Installer\FraudFailStateInstaller" public="true">
            <argument type="service" id="MaxMind\Service\Installer\StateInstallerHelper"/>
        </service>

        <service id="MaxMind\Service\Installer\CompleteStateInstaller" public="true">
            <argument type="service" id="MaxMind\Service\Installer\StateInstallerHelper"/>
        </service>

        <service id="MaxMind\Service\Installer\InProgressStateInstaller" public="true">
            <argument type="service" id="MaxMind\Service\Installer\StateInstallerHelper"/>
        </service>

        <service id="MaxMind\Service\Installer\CancelledStateInstaller" public="true">
            <argument type="service" id="MaxMind\Service\Installer\StateInstallerHelper"/>
        </service>

        <service id="MaxMind\Service\Installer\FraudReviewCustomFieldsInstaller" public="true">
            <argument type="service" id="custom_field_set.repository"/>
            <argument type="service" id="custom_field_set_relation.repository"/>
            <argument type="service" id="service_container"/>
        </service>

        <service id="MaxMind\Service\MaxMindAverageService">
            <argument type="service" id="order.repository"/>
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="logger"/>
        </service>

        <service id="MaxMind\ScheduledTask\CalculateRiskAveragesTask">
            <tag name="shopware.scheduled.task"/>
        </service>
        <service id="MaxMind\Service\CookieProvider" decorates="Shopware\Storefront\Framework\Cookie\CookieProviderInterface">
            <argument type="service" id="MaxMind\Service\CookieProvider.inner"/>
        </service>

        <service id="MaxMind\Service\MaxMindConnectionTester">
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="logger"/>
        </service>
        <service id="MaxMind\ScheduledTask\CalculateRiskAveragesTaskHandler">
            <argument type="service" id="scheduled_task.repository"/>
            <argument type="service" id="MaxMind\Service\MaxMindAverageService"/>
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="logger"/>
            <tag name="messenger.message_handler"/>
        </service>

        <service id="MaxMind\Controller\Admin\MaxMindConnectionController" public="true">
            <argument type="service" id="MaxMind\Service\MaxMindConnectionTester"/>
            <tag name="controller.service_arguments"/>
        </service>

        <service id="MaxMind\MessageHandler\FraudCheckMessageHandler">
            <argument type="service" id="MaxMind\Service\MaxMindFraudService"/>
            <argument type="service" id="logger"/>
            <tag name="messenger.message_handler"/>
        </service>
    </services>
</container>
